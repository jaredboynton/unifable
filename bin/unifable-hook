#!/usr/bin/env bash
# Dispatch a unifable hook script from the resolved plugin root.
# Stable entrypoint for hooks.json — survives versioned cache dir churn after upgrades.
# Fail open: resolver errors emit {} and exit 0 so the host is never bricked.
set -uo pipefail

script="${1:-}"
if [ -z "$script" ]; then
  echo "{}"
  exit 0
fi

_resolve_bootstrap_root() {
  local s="${BASH_SOURCE[0]}"
  while [ -L "$s" ]; do
    local dir
    dir="$(cd "$(dirname "$s")" && pwd)"
    s="$(readlink "$s")"
    case "$s" in /*) ;; *) s="$dir/$s";; esac
  done
  local here
  here="$(cd "$(dirname "$s")" && pwd)"
  cd "$here/.." && pwd
}

_plugin_hint="$(_resolve_bootstrap_root)"

ROOT="$(
  UNIFABLE_DISPATCH_BOOTSTRAP="$_plugin_hint" python3 -c "
import os, sys
from pathlib import Path

bootstrap = Path(os.environ.get('UNIFABLE_DISPATCH_BOOTSTRAP', '')).expanduser()
if not bootstrap.is_dir():
    raise SystemExit(0)
sys.path.insert(0, str(bootstrap / 'scripts' / 'gate'))
from plugin_root import resolve_plugin_root

root = resolve_plugin_root(bootstrap)
print(root or '')
" 2>/dev/null || true
)"

if [ -z "$ROOT" ] || [ ! -f "$ROOT/hooks/$script" ]; then
  echo "{}"
  exit 0
fi

export PLUGIN_ROOT="$ROOT"
export CLAUDE_PLUGIN_ROOT="$ROOT"
export UNIFABLE_PLUGIN_ROOT="$ROOT"

target="$ROOT/hooks/$script"
case "$script" in
  *.sh) exec bash "$target" ;;
  *) exec python3 "$target" ;;
esac
