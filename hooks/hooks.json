{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "unifable-hook router.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "unifable-hook gate_prompt.py",
            "timeout": 95
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "unifable-hook gate_prompt_effort.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|Task|Agent|Edit|Write|MultiEdit|NotebookEdit|apply_patch)$",
        "hooks": [
          {
            "type": "command",
            "command": "unifable-hook pre_tool_use.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "unifable-hook gate_post_tool.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^(Edit|Write|MultiEdit|NotebookEdit|apply_patch)$",
        "hooks": [
          {
            "type": "command",
            "command": "unifable-hook test_after_edit.py",
            "timeout": 75
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "unifable-hook gate_stop.py",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
