{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.local/bin/unifable-hook\" session_start.py",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.local/bin/unifable-hook\" gate_prompt.py",
            "timeout": 95
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|REPL|exec_command|Shell|Task|Agent|Edit|Write|MultiEdit|NotebookEdit|apply_patch|mcp__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.local/bin/unifable-hook\" pre_tool_use.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.local/bin/unifable-hook\" gate_post_tool.py",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.local/bin/unifable-hook\" gate_stop.py",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
