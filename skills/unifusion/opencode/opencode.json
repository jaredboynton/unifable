{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai-ws": {
      "name": "OpenAI WebSocket",
      "npm": "@ai-sdk/openai",
      "api": "https://api.openai.com/v1",
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5 (WebSocket)",
          "attachment": true,
          "reasoning": true,
          "temperature": false,
          "tool_call": true,
          "limit": { "context": 272000, "input": 272000, "output": 128000 },
          "variants": {
            "low": { "reasoningEffort": "low", "include": ["reasoning.encrypted_content"] },
            "medium": { "reasoningEffort": "medium", "include": ["reasoning.encrypted_content"] },
            "high": { "reasoningEffort": "high", "include": ["reasoning.encrypted_content"] },
            "xhigh": { "reasoningEffort": "xhigh", "include": ["reasoning.encrypted_content"] }
          }
        }
      }
    }
  },
  "agent": {
    "architect": {
      "description": "Unifusion frontier-research architect backed by GPT-5.5.",
      "mode": "primary",
      "model": "openai-ws/gpt-5.5",
      "prompt": "{file:./architect_prompt.md}",
      "tools": { "write": false, "edit": false, "patch": false, "bash": false }
    },
    "architect-opus": {
      "description": "Unifusion frontier-research architect backed by Claude Opus 4.8 on Bedrock.",
      "mode": "primary",
      "model": "amazon-bedrock/us.anthropic.claude-opus-4-8",
      "prompt": "{file:./architect_prompt.md}",
      "tools": { "write": false, "edit": false, "patch": false, "bash": false }
    },
    "architect-glm": {
      "description": "Unifusion frontier-research architect backed by GLM-5.2.",
      "mode": "primary",
      "model": "zai-coding-plan/glm-5.2",
      "prompt": "{file:./architect_prompt.md}",
      "tools": { "write": false, "edit": false, "patch": false, "bash": false }
    },
    "architect-kimi": {
      "description": "Unifusion frontier-research architect backed by Kimi K2.7.",
      "mode": "primary",
      "model": "kimi-for-coding/k2p7",
      "prompt": "{file:./architect_prompt.md}",
      "tools": { "write": false, "edit": false, "patch": false, "bash": false }
    },
    "unifusion-synth": {
      "description": "Unifusion synthesis orchestrator backed by GPT-5.5.",
      "mode": "primary",
      "model": "openai-ws/gpt-5.5",
      "prompt": "{file:./synth_prompt.md}",
      "tools": { "write": false, "edit": false, "patch": false, "bash": false }
    }
  }
}
