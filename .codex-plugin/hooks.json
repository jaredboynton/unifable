{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "\"${HOME}/.local/bin/unifable-hook\" session_start.py", "timeout": 30 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "\"${HOME}/.local/bin/unifable-hook\" gate_prompt.py", "statusMessage": "routing, classifying task mode, effort playbook", "timeout": 95 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|REPL|exec_command|Task|Agent|Edit|Write|MultiEdit|NotebookEdit|apply_patch)$",
        "hooks": [
          { "type": "command", "command": "\"${HOME}/.local/bin/unifable-hook\" pre_tool_use.py", "statusMessage": "pre-edit/bash/delegation spec gate", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "\"${HOME}/.local/bin/unifable-hook\" gate_post_tool.py", "statusMessage": "observing tool evidence", "timeout": 120 }
        ]
      },
      {
        "matcher": "^(Edit|Write|MultiEdit|NotebookEdit|apply_patch)$",
        "hooks": [
          { "type": "command", "command": "\"${HOME}/.local/bin/unifable-hook\" test_after_edit.py", "statusMessage": "test-after-edit", "timeout": 75 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "\"${HOME}/.local/bin/unifable-hook\" gate_stop.py", "statusMessage": "completion verification gate", "timeout": 120 }
        ]
      }
    ]
  }
}
