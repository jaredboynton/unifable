{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/router.sh\"", "statusMessage": "unifable: routing task signal to pack", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "python3 \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/gate_prompt.py\"", "statusMessage": "unifable: classifying task mode", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "python3 \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/gate_prompt_effort.py\"", "statusMessage": "unifable: effort-gated playbook injection", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Edit|Write|MultiEdit|NotebookEdit|apply_patch)$",
        "hooks": [
          { "type": "command", "command": "python3 \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/pre_tool_use.py\"", "statusMessage": "unifable: pre-edit spec gate", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|apply_patch)$",
        "hooks": [
          { "type": "command", "command": "python3 \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/gate_post_tool.py\"", "statusMessage": "unifable: observing tool evidence", "timeout": 10 }
        ]
      },
      {
        "matcher": "^(Edit|Write|MultiEdit|NotebookEdit|apply_patch)$",
        "hooks": [
          { "type": "command", "command": "python3 \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/test_after_edit.py\"", "statusMessage": "unifable: test-after-edit", "timeout": 75 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python3 \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/gate_stop.py\"", "statusMessage": "unifable: completion verification gate", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "bash \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/finish-the-work.sh\"", "statusMessage": "unifable: promise-no-act guard", "timeout": 10 }
        ]
      }
    ]
  }
}
