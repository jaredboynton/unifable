{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "unifable-hook router.sh", "statusMessage": "unifable: routing task signal to pack", "timeout": 10 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "unifable-hook gate_prompt.py", "statusMessage": "unifable: classifying task mode", "timeout": 95 }
        ]
      },
      {
        "hooks": [
          { "type": "command", "command": "unifable-hook gate_prompt_effort.py", "statusMessage": "unifable: effort-gated playbook injection", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|Task|Agent|Edit|Write|MultiEdit|NotebookEdit|apply_patch)$",
        "hooks": [
          { "type": "command", "command": "unifable-hook pre_tool_use.py", "statusMessage": "unifable: pre-edit/bash/delegation spec gate", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "unifable-hook gate_post_tool.py", "statusMessage": "unifable: observing tool evidence", "timeout": 10 }
        ]
      },
      {
        "matcher": "^(Edit|Write|MultiEdit|NotebookEdit|apply_patch)$",
        "hooks": [
          { "type": "command", "command": "unifable-hook test_after_edit.py", "statusMessage": "unifable: test-after-edit", "timeout": 75 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "unifable-hook gate_stop.py", "statusMessage": "unifable: completion verification gate", "timeout": 120 }
        ]
      }
    ]
  }
}
