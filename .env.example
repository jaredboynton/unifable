# unifable local environment template.
# Copy to .env or export selectively in your shell. Leave secret values blank here.

# Core runtime paths.
UNIFABLE_HOME=
UNIFABLE_DATA=
UNIFABLE_BIN_DIR=
UNIFABLE_PROJECT_ROOT=

# Gate behavior overrides. Leave unset for the default routing path.
UNIFABLE_GRADE=
UNIFABLE_VERIFY_CITATIONS=1
UNIFABLE_STOP_BUDGET=100
UNIFABLE_JUDGE_MODEL=gpt-realtime-2
UNIFABLE_JUDGE_DAEMON=1

# Optional debounced test runner after edits.
UNIFABLE_TEST_AFTER_EDIT=
UNIFABLE_TEST_DEBOUNCE=45
UNIFABLE_TEST_TIMEOUT=60

# Optional unifusion panel settings.
UNIFUSION_TIMEOUT=600
UNIFUSION_OPUS_MODEL=opus
UNIFUSION_CODEX_MODEL=gpt-5.5
KIMI_MODEL=
DEVIN_MODEL=glm-5.2
AGY_MODEL=Gemini 3.5 Flash (Medium)
UNIFUSION_AGY_NO_MODEL=

# Optional unifusion session-context credentials.
GEMINI_API_KEY=
GOOGLE_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
